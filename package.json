{
  "name": "medicine-tracker",
  "version": "1.0.0",
  "description": "Medicine Expiry Date Tracking System - Backend API",
  "main": "src/app.js",
  "type": "module",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "seed": "node src/utils/seed.js",
    "seed:users": "node src/utils/seed_users.js",
    "seed:medicines": "node src/utils/seed_medicines.js",
    "seed:all": "node src/utils/seed.js && node src/utils/seed_users.js && node src/utils/seed_medicines.js",
    "build": "echo 'No build step needed for Node.js backend'",
    "test": "jest --runInBand",
    "test:watch": "jest --watch --runInBand",
    "test:perf": "set NODE_ENV=test&& node src/tests/performance/summary.js",
    "test:benchmark": "set NODE_ENV=test&& node src/tests/performance/benchmark.js"
  },
  "keywords": [
    "pharmacy",
    "medicine",
    "expiry",
    "tracking"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-rate-limit": "^6.10.0",
    "helmet": "^7.0.0",
    "joi": "^17.10.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.10.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "artillery": "^2.0.31",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "transform": {
      "^.+\\.js$": "babel-jest"
    }
  }
}
